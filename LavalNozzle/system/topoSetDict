actions
(
    {
        name    dampingCells;
        type    cellSet;
        action  new;
        source  boxToCell;
        box     (300 0 -1) (500 50 1);
    }

    {
        name    dampingZone;
        type    cellZoneSet;
        action  new;
        source  setToCellZone;
        set     dampingCells;
    }
);

